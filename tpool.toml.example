# tpool configuration file

# Socket path (optional, defaults to $XDG_RUNTIME_DIR/tpool-$UID.sock)
# socket = "/tmp/tpool.sock"

# Web interface configuration (disabled by default)
[web]
enabled = true
address = ":8080"

# Ngrok configuration (optional)
# When configured, the web interface will be exposed via ngrok
# instead of listening on the local address.
# [web.ngrok]
# url = "https://your-domain.ngrok.app"  # Your ngrok domain or leave empty for random URL
#
# # OAuth configuration (optional)
# # Restricts access to authenticated users only
# [web.ngrok.oauth]
# provider = "github"  # Options: "github", "google"
# allowed_users = ["username1", "username2"]  # GitHub usernames or Google emails
